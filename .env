# Database (use a local Postgres or managed service)
DJANGO_DATABASE_HOST=postgres
DJANGO_DATABASE_PORT=5432
POSTGRES_DB=validata
POSTGRES_USER=validata
POSTGRES_PASSWORD=validata

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASS=

# Caddy / app
CADDY_SITE_ADDRESS=:80

# Image to run (replace with registry image)
VALIDATA_API_IMAGE=nginx:alpine
